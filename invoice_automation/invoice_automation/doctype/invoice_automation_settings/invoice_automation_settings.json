 "fields": [
  {
   "fieldname": "sb_llm_providers",
   "fieldtype": "Section Break",
   "label": "LLM Provider Configuration"
  },
  {
   "default": "Ollama",
   "description": "LLM provider for invoice data extraction and image parsing",
   "fieldname": "extraction_llm_provider",
   "fieldtype": "Select",
   "label": "Extraction LLM Provider",
   "options": "Ollama\nOpenAI\nAnthropic\nGemini"
  },
  {
   "default": "Anthropic",
   "description": "LLM provider for Stage 5 matching (item/supplier matching fallback)",
   "fieldname": "matching_llm_provider",
   "fieldtype": "Select",
   "label": "Matching LLM Provider",
   "options": "Ollama\nOpenAI\nAnthropic\nGemini"
  },
  {
   "default": "3",
   "description": "Retries when LLM returns malformed JSON (applies to all providers)",
   "fieldname": "json_retry_count",
   "fieldtype": "Int",
   "label": "JSON Retry Count"
  },
  {
   "fieldname": "cb_llm_providers",
   "fieldtype": "Column Break"
  },
  {
   "depends_on": "eval:doc.extraction_llm_provider=='OpenAI' || doc.matching_llm_provider=='OpenAI'",
   "fieldname": "openai_api_key",
   "fieldtype": "Password",
   "label": "OpenAI API Key"
  },
  {
   "default": "gpt-4o",
   "depends_on": "eval:doc.extraction_llm_provider=='OpenAI' || doc.matching_llm_provider=='OpenAI'",
   "fieldname": "openai_model",
   "fieldtype": "Data",
   "label": "OpenAI Model"
  },
  {
   "depends_on": "eval:doc.extraction_llm_provider=='Gemini' || doc.matching_llm_provider=='Gemini'",
