   "fieldtype": "Data",
   "label": "Gemini Model"
  },
  {
   "depends_on": "eval:doc.extraction_llm_provider=='Ollama' || doc.matching_llm_provider=='Ollama'",
   "fieldname": "sb_ollama",
   "fieldtype": "Section Break",
   "label": "Ollama Configuration"
  },
  {
   "default": "http://localhost:11434",
   "fieldname": "ollama_base_url",
   "fieldtype": "Data",
   "label": "Ollama Base URL"
  },
  {
   "default": "qwen2.5vl:7b",
   "fieldname": "ollama_model",
   "fieldtype": "Data",
   "label": "Ollama Model"
  },
  {
   "fieldname": "cb_ollama",
   "fieldtype": "Column Break"
  },
  {
   "default": "120",
   "fieldname": "ollama_timeout_seconds",
   "fieldtype": "Int",
   "label": "Ollama Timeout (seconds)"
  },
  {
   "depends_on": "eval:doc.extraction_llm_provider=='Ollama' || doc.extraction_llm_provider=='OpenAI' || doc.extraction_llm_provider=='Anthropic' || doc.extraction_llm_provider=='Gemini'",
   "fieldname": "sb_llamaparse",
   "fieldtype": "Section Break",
   "label": "LlamaParse Configuration (Optional PDF Parser)"
  },
  {
   "description": "Optional. If set, LlamaParse is used as the first-choice PDF parser before falling back to PyMuPDF/LLM vision.",
   "fieldname": "llamaparse_api_key",
   "fieldtype": "Password",
   "label": "LlamaParse API Key"
  },
  {
   "fieldname": "cb_llamaparse",
   "fieldtype": "Column Break"
  },
  {
   "default": "markdown",
   "fieldname": "llamaparse_result_type",
   "fieldtype": "Select",
   "label": "LlamaParse Result Type",
   "options": "markdown\ntext"
  },
  {
   "fieldname": "sb_matching",
   "fieldtype": "Section Break",
   "label": "Matching Thresholds"
  },
  {
   "default": "90",
   "description": "Minimum confidence (0-100) to auto-create a Purchase Invoice without review. Must be >= Review Threshold.",
   "fieldname": "auto_create_threshold",
   "fieldtype": "Float",
   "label": "Auto Create Threshold (%)"
  },
  {
   "default": "60",
   "description": "Invoices with confidence between this and Auto Create route to the Review Queue. Below this goes to Manual Entry.",
   "fieldname": "review_threshold",
   "fieldtype": "Float",
   "label": "Review Threshold (%)"
  },
  {
   "default": "85",
   "description": "Minimum fuzzy text similarity score (0-100) for Stage 3 matching to consider a match",
   "fieldname": "fuzzy_match_threshold",
   "fieldtype": "Float",
   "label": "Fuzzy Match Threshold"
  },
  {
   "fieldname": "cb_matching",
   "fieldtype": "Column Break"
  },
  {
   "default": "1",
   "description": "Use LLM as Stage 5 fallback when earlier stages fail or have low confidence",
   "fieldname": "enable_llm_matching",
   "fieldtype": "Check",
   "label": "Enable LLM Matching"
  },
  {
   "default": "0",
   "description": "Automatically create Draft Purchase Invoices when confidence meets auto-create threshold. Disable until the system has learned enough from corrections.",
   "fieldname": "enable_auto_create",
   "fieldtype": "Check",
   "label": "Enable Auto Create"
  },
  {
   "default": "10",
   "description": "Maximum number of candidate items/suppliers sent to the LLM for Stage 5 matching",
   "fieldname": "llm_max_candidates",
   "fieldtype": "Int",
   "label": "LLM Max Candidates"
  },
  {
   "default": "5",
   "description": "Maximum number of historical corrections included as context for LLM matching",
   "fieldname": "llm_max_corrections_context",
   "fieldtype": "Int",
   "label": "LLM Max Corrections Context"
  },
  {
   "fieldname": "sb_embedding",
   "fieldtype": "Section Break",
   "label": "Embedding Configuration"
  },
  {
   "default": "0.85",
   "description": "Cosine similarity threshold (0-1) for Stage 4 embedding match to auto-accept. Values above this are high-confidence matches.",
   "fieldname": "embedding_similarity_threshold",
   "fieldtype": "Float",
   "label": "Embedding Similarity Threshold"
  },
  {
   "default": "0.65",
   "description": "Cosine similarity threshold (0-1) below which embedding matches are discarded. Between this and similarity threshold routes to review.",
   "fieldname": "embedding_review_threshold",
   "fieldtype": "Float",
   "label": "Embedding Review Threshold"
  },
  {
   "default": "1.1",
   "description": "Multiplier applied to similarity scores for items that were previously corrected by humans (e.g. 1.1 = 10% boost)",
   "fieldname": "human_correction_weight_boost",
   "fieldtype": "Float",
   "label": "Human Correction Weight Boost"
  },
  {
   "default": "10",
   "description": "Percentage points added to confidence when multiple matching stages agree on the same result",
   "fieldname": "agreement_confidence_boost",
   "fieldtype": "Float",
   "label": "Agreement Confidence Boost (%)"
  },
  {
   "fieldname": "cb_embedding",
   "fieldtype": "Column Break"
  },
  {
   "default": "sentence-transformers/all-MiniLM-L6-v2",
